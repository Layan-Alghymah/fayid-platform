# Hostinger npm install settings for the frontend package.
# --ignore-scripts prevents react-hook-form@7.76.0 (and similar packages that
# accidentally ship "prepare": "husky" in their published package.json) from
# failing the install with "husky is not recognised as a command".
# esbuild still works because Vite uses it as a JS module; its Linux binary
# is installed as an optional dependency (@esbuild/linux-x64) — no postinstall needed.
ignore-scripts=true
legacy-peer-deps=true
